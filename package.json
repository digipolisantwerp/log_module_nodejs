{
  "name": "@digipolis/log",
  "version": "1.1.1",
  "keywords": [
    "digipolis",
    "antwerpen",
    "log",
    "logger"
  ],
  "description": "Logging tool for Digipolis kibana logging",
  "main": "lib/index.js",
  "scripts": {
    "start": "node --watch ./example/index.js",
    "test": "node --test --test-force-exit",
    "lint": "eslint \"**/*.js\"",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/*.mjs' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=./coverage/lcov.info --test-force-exit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digipolisantwerp/log_module_nodejs.git"
  },
  "author": "Olivier Van den Mooter",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsonschema": "^1.5.0",
    "sinon": "^22.0.0"
  }
}
